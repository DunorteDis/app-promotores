{
  "expo": {
    "name": "Vexo",
    "slug": "vexo",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "icon": "./assets/icon_transparent.png",
    "scheme": "dunortevexo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon_transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#1565C0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.dunorte.vexo",
      "icon": "./assets/icon_transparent.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Precisamos da sua localização para registrar visitas e rotas de promotor.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Precisamos da sua localização para registrar visitas e rotas de promotor.",
        "NSCameraUsageDescription": "Necessário para capturar fotos nas visitas.",
        "NSMicrophoneUsageDescription": "Necessário para capturar fotos e vídeos nas visitas.",
        "NSPhotoLibraryUsageDescription": "Necessário para selecionar fotos da galeria nas visitas.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "4",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "br.com.dunorte.vexo",
      "icon": "./assets/icon_transparent.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/playstore_adaptive_fg.png",
        "backgroundColor": "#1565C0"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_NETWORK_STATE",
        "INTERNET",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_NETWORK_STATE",
        "INTERNET",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ],
      "versionCode": 3
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permita o acesso à sua localização para registrar visitas."
        }
      ],
      "expo-notifications",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "O aplicativo acessa suas fotos para registrar visitas.",
          "cameraPermission": "O aplicativo usa a câmera para registrar fotos das visitas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e184325c-6e10-4e3d-95e0-7d2800aae76b"
      }
    },
    "owner": "edbr0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e184325c-6e10-4e3d-95e0-7d2800aae76b"
    }
  }
}
