{
  "expo": {
    "name": "Vexo",
    "slug": "app-promotores-dunorte",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_transparent.png",
    "scheme": "dunortepromotores",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon_transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#1565C0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.dunorte.promotores",
      "icon": "./assets/icon_transparent.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Precisamos da sua localização para registrar visitas e rotas de promotor.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Precisamos da sua localização para registrar visitas e rotas de promotor.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "br.com.dunorte.promotores",
      "icon": "./assets/icon_transparent.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/playstore_adaptive_fg.png",
        "backgroundColor": "#1565C0"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_NETWORK_STATE",
        "INTERNET",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/Assets.xcassets/AppIcon.appiconset/_/64.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permita o acesso à sua localização para registrar visitas."
        }
      ],
      "expo-notifications",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f3d01d6-317b-4437-9bab-aefdd493fd6c"
      }
    },
    "owner": "edbr0"
  }
}
